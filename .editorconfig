# Owlat editor defaults — mirrors oxfmt (useTabs, tabWidth 2, printWidth 100).
# See oxfmtrc.json; `bun run ox:fmt` is the source of truth for formatting.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 2
max_line_length = 100

# YAML does not permit tab indentation.
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Don't strip trailing whitespace in Markdown (two trailing spaces = hard break).
[*.md]
trim_trailing_whitespace = false

[*.{json,jsonc}]
indent_style = tab
indent_size = 2
