#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════════════════════
# owlat — thin CLI wrapper around docker compose + the in-app update pipeline.
#
# Installed by install.sh to /usr/local/bin/owlat. Always operates from
# $OWLAT_DIR (default: /opt/owlat). Hides docker-compose ceremony and acts as
# the natural home for ops commands.
#
# Subcommands:
#   owlat quickstart          — first-run install wizard (the blessed path)
#   owlat setup               — alias for quickstart (containerized TS CLI)
#   owlat setup --legacy      — run the legacy bash setup.sh
#   owlat config              — re-open the wizard for an existing install
#   owlat feature <key> on|off — toggle a single feature flag
#   owlat env <KEY> <VALUE>   — set a single env var in .env
#   owlat start               — docker compose up -d
#   owlat stop                — docker compose down
#   owlat restart [service]   — docker compose restart [service]
#   owlat status              — docker compose ps
#   owlat logs [service]      — docker compose logs -f [service]
#   owlat doctor              — diagnose a broken install
#   owlat upgrade             — trigger in-app update to latest
#   owlat upgrade --version X — pin to a specific semver version
#   owlat backup [path]       — bash scripts/backup.sh [path]
#   owlat backup-schedule [enable|disable|status] — daily automatic backups (systemd timer / cron)
#   owlat restore <file>      — bash scripts/restore.sh <file>
#   owlat shell <service>     — docker compose exec <service> sh
#   owlat version             — print stack version
#   owlat --help              — this help
# ═══════════════════════════════════════════════════════════════════════════════
set -euo pipefail

OWLAT_DIR="${OWLAT_DIR:-/opt/owlat}"

# Fall back to the repo root if we were invoked from inside a clone
if [[ ! -f "$OWLAT_DIR/docker-compose.yml" ]]; then
	# Resolve symlinks to find the script's real location
	SCRIPT_PATH="${BASH_SOURCE[0]}"
	while [[ -L "$SCRIPT_PATH" ]]; do
		SCRIPT_PATH=$(readlink "$SCRIPT_PATH")
	done
	REPO_ROOT=$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)
	if [[ -f "$REPO_ROOT/docker-compose.yml" ]]; then
		OWLAT_DIR="$REPO_ROOT"
	fi
fi

if [[ ! -f "$OWLAT_DIR/docker-compose.yml" ]]; then
	echo "Error: docker-compose.yml not found in $OWLAT_DIR" >&2
	echo "Set OWLAT_DIR=/path/to/your/owlat/clone to override." >&2
	exit 1
fi

cd "$OWLAT_DIR"

# ── Colors ────────────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
	CYAN='\033[0;36m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'
else
	CYAN=''; GREEN=''; YELLOW=''; RED=''; BOLD=''; DIM=''; RESET=''
fi

show_help() {
	# Print the whole subcommand block from the header comment (through `--help`).
	sed -n '4,29p' "$0" | sed 's/^# \{0,1\}//'
}

# ── Scheduled backups ─────────────────────────────────────────────────────────
# Install/remove a recurring `bash scripts/backup.sh` job so a self-hoster ends
# up with automatic backups instead of only the on-demand `owlat backup`.
# Prefers a systemd timer; falls back to a /etc/cron.d entry; no-ops with a
# clear message where neither is available. Idempotent: enable overwrites the
# unit/cron files, disable tolerates an already-removed job.
BACKUP_SCHEDULE_ONCALENDAR="*-*-* 04:00:00"   # systemd OnCalendar: daily at 04:00
BACKUP_SCHEDULE_CRON="0 4 * * *"              # cron: daily at 04:00
BACKUP_UNIT_NAME="owlat-backup"
BACKUP_SERVICE_FILE="/etc/systemd/system/${BACKUP_UNIT_NAME}.service"
BACKUP_TIMER_FILE="/etc/systemd/system/${BACKUP_UNIT_NAME}.timer"
BACKUP_CRON_FILE="/etc/cron.d/owlat-backup"

# Run a privileged command as root (no-op prefix when already root, sudo when not).
_root() {
	if [[ "$(id -u)" -eq 0 ]]; then
		"$@"
	elif command -v sudo >/dev/null 2>&1; then
		sudo "$@"
	else
		echo "Error: writing system files needs root — install sudo or run as root." >&2
		return 1
	fi
}

# The unit/timer/cron CONTENT is generated by these pure echo helpers so the
# schedule + the exact backup command are defined in exactly one place.
backup_systemd_service_unit() {
	cat <<EOF
[Unit]
Description=Owlat backup (scripts/backup.sh)
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
WorkingDirectory=${OWLAT_DIR}
ExecStart=/usr/bin/env bash ${OWLAT_DIR}/scripts/backup.sh
EOF
}

backup_systemd_timer_unit() {
	cat <<EOF
[Unit]
Description=Daily Owlat backup

[Timer]
OnCalendar=${BACKUP_SCHEDULE_ONCALENDAR}
Persistent=true

[Install]
WantedBy=timers.target
EOF
}

backup_cron_line() {
	echo "${BACKUP_SCHEDULE_CRON} root cd ${OWLAT_DIR} && bash scripts/backup.sh >> /var/log/owlat-backup.log 2>&1"
}

backup_schedule_enable() {
	if command -v systemctl >/dev/null 2>&1; then
		backup_systemd_service_unit | _root tee "$BACKUP_SERVICE_FILE" >/dev/null
		backup_systemd_timer_unit   | _root tee "$BACKUP_TIMER_FILE"   >/dev/null
		_root systemctl daemon-reload
		_root systemctl enable --now "${BACKUP_UNIT_NAME}.timer"
		printf '%b\n' "${GREEN}${BOLD}[ ok ]${RESET} Scheduled daily backups via systemd timer."
		printf '  Service: %s\n' "$BACKUP_SERVICE_FILE"
		printf '  Timer:   %s  (OnCalendar=%s)\n' "$BACKUP_TIMER_FILE" "$BACKUP_SCHEDULE_ONCALENDAR"
		printf '  Runs:    bash %s/scripts/backup.sh\n' "$OWLAT_DIR"
		printf '  Inspect: systemctl list-timers %s.timer\n' "$BACKUP_UNIT_NAME"
	elif [[ -d /etc/cron.d ]]; then
		backup_cron_line | _root tee "$BACKUP_CRON_FILE" >/dev/null
		_root chmod 0644 "$BACKUP_CRON_FILE"
		printf '%b\n' "${GREEN}${BOLD}[ ok ]${RESET} Scheduled daily backups via cron."
		printf '  File: %s  (%s)\n' "$BACKUP_CRON_FILE" "$BACKUP_SCHEDULE_CRON"
		printf '  Runs: bash %s/scripts/backup.sh\n' "$OWLAT_DIR"
	else
		printf '%b\n' "${YELLOW}${BOLD}[warn]${RESET} Neither systemd nor /etc/cron.d is available here." >&2
		printf '  Add your own scheduler to run daily: cd %s && bash scripts/backup.sh\n' "$OWLAT_DIR" >&2
		return 1
	fi
}

backup_schedule_disable() {
	local removed=0
	if command -v systemctl >/dev/null 2>&1; then
		if systemctl list-unit-files 2>/dev/null | grep -q "^${BACKUP_UNIT_NAME}.timer"; then
			_root systemctl disable --now "${BACKUP_UNIT_NAME}.timer" >/dev/null 2>&1 || true
		fi
		if [[ -f "$BACKUP_TIMER_FILE" || -f "$BACKUP_SERVICE_FILE" ]]; then
			_root rm -f "$BACKUP_TIMER_FILE" "$BACKUP_SERVICE_FILE"
			_root systemctl daemon-reload
			removed=1
		fi
	fi
	if [[ -f "$BACKUP_CRON_FILE" ]]; then
		_root rm -f "$BACKUP_CRON_FILE"
		removed=1
	fi
	if [[ "$removed" -eq 1 ]]; then
		printf '%b\n' "${GREEN}${BOLD}[ ok ]${RESET} Scheduled backups disabled."
	else
		echo "No scheduled backups were installed — nothing to disable."
	fi
}

backup_schedule_status() {
	local found=0
	if command -v systemctl >/dev/null 2>&1 && [[ -f "$BACKUP_TIMER_FILE" ]]; then
		found=1
		printf '%b\n' "${CYAN}${BOLD}[info]${RESET} systemd timer installed (${BACKUP_UNIT_NAME}.timer):"
		systemctl list-timers "${BACKUP_UNIT_NAME}.timer" --no-pager 2>/dev/null \
			|| systemctl status "${BACKUP_UNIT_NAME}.timer" --no-pager 2>/dev/null || true
	fi
	if [[ -f "$BACKUP_CRON_FILE" ]]; then
		found=1
		printf '%b\n' "${CYAN}${BOLD}[info]${RESET} cron entry installed at ${BACKUP_CRON_FILE}:"
		cat "$BACKUP_CRON_FILE"
	fi
	if [[ "$found" -eq 0 ]]; then
		echo "No scheduled backups installed."
		echo "Enable daily backups with: owlat backup-schedule enable"
	fi
}

backup_schedule() {
	local action="${1:-status}"
	case "$action" in
		enable)  backup_schedule_enable ;;
		disable) backup_schedule_disable ;;
		status)  backup_schedule_status ;;
		*)
			echo "Usage: owlat backup-schedule [enable|disable|status]" >&2
			return 2
			;;
	esac
}

# ── Subcommands ───────────────────────────────────────────────────────────────
cmd="${1:-help}"
shift || true

# Pin the wizard image to the OWLAT_VERSION this install was deployed at, so a
# day-2 `owlat quickstart`/`owlat config` runs the SAME wizard as the running
# stack rather than a mutable ':latest' that can drift from the pinned sources.
# Precedence: an explicit OWLAT_VERSION in the environment, else the
# OWLAT_VERSION pinned in $OWLAT_DIR/.env (written by quickstart), else 'latest'.
OWLAT_VERSION_TAG="${OWLAT_VERSION:-}"
if [[ -z "$OWLAT_VERSION_TAG" && -f "$OWLAT_DIR/.env" ]]; then
	OWLAT_VERSION_TAG="$(grep -E '^OWLAT_VERSION=' "$OWLAT_DIR/.env" | tail -1 | cut -d= -f2- | tr -d '"' | tr -d "'" || true)"
fi
OWLAT_VERSION_TAG="${OWLAT_VERSION_TAG:-latest}"
OWLAT_SETUP_IMAGE="${OWLAT_SETUP_IMAGE:-ghcr.io/wolvesdotink/setup:${OWLAT_VERSION_TAG}}"

# Run the TS setup CLI inside the owlat/setup container.
# Falls back to legacy bash wizard with --legacy.
run_setup_container() {
	# Pass through interactive TTY when available, mount the install dir, forward env.
	local tty_flag=""
	[[ -t 1 ]] && tty_flag="-it"
	docker run --rm $tty_flag \
		-v "$OWLAT_DIR:/opt/owlat" \
		-e "OWLAT_DIR=/opt/owlat" \
		-e "OWLAT_ASSUME_YES=${OWLAT_ASSUME_YES:-0}" \
		"$OWLAT_SETUP_IMAGE" "$@"
}

# ── Host config-file bind-mount ───────────────────────────────────────────────
# A setup config file lives on the host, but the wizard container only sees
# $OWLAT_DIR (mounted at /opt/owlat) — the host path is invisible inside it.
# Bind-mount the file at a fixed in-container path and rewrite the --config
# argument to point there. Driven by OWLAT_CONFIG_FILE (exported by install.sh)
# or an inline `--config <host-path>` flag on a wizard subcommand.
OWLAT_CONFIG_FILE="${OWLAT_CONFIG_FILE:-}"
CONFIG_IN_CONTAINER="/opt/owlat/.owlat-setup-config"
CONFIG_MOUNT_ARGS=()
case "$cmd" in
	setup|quickstart|config)
		# The bash wizard (--legacy) runs on the host, where the original config
		# path is valid; only the containerized path needs the bind-mount +
		# in-container rewrite, so skip it entirely when --legacy is requested.
		config_is_legacy=0
		for arg in "$@"; do
			[[ "$arg" == "--legacy" ]] && config_is_legacy=1
		done
		if [[ "$config_is_legacy" == "0" ]]; then
			# Pull an inline `--config <host-path>` out of the args, if present, so
			# we can mount it and substitute the in-container path below.
			config_passthrough=()
			while [[ $# -gt 0 ]]; do
				case "$1" in
					--config)
						OWLAT_CONFIG_FILE="${2:-}"
						shift 2 || shift
						;;
					--config=*)
						OWLAT_CONFIG_FILE="${1#*=}"
						shift
						;;
					*)
						config_passthrough+=("$1")
						shift
						;;
				esac
			done
			set -- ${config_passthrough[@]+"${config_passthrough[@]}"}
			if [[ -n "$OWLAT_CONFIG_FILE" ]]; then
				if [[ ! -r "$OWLAT_CONFIG_FILE" ]]; then
					echo "Error: OWLAT_CONFIG_FILE is not readable: $OWLAT_CONFIG_FILE" >&2
					exit 1
				fi
				CONFIG_MOUNT_ARGS=(-v "$OWLAT_CONFIG_FILE:$CONFIG_IN_CONTAINER:ro")
				set -- "$@" --config "$CONFIG_IN_CONTAINER"
			fi
		fi
		;;
esac

case "$cmd" in
	setup)
		# Allow --legacy to fall back to the bash wizard.
		for arg in "$@"; do
			if [[ "$arg" == "--legacy" ]]; then
				exec bash scripts/setup.sh "$@"
			fi
		done
		exec docker run --rm $([ -t 1 ] && echo "-it") \
			-v "$OWLAT_DIR:/opt/owlat" \
			${CONFIG_MOUNT_ARGS[@]+"${CONFIG_MOUNT_ARGS[@]}"} \
			-e "OWLAT_DIR=/opt/owlat" \
			-e "OWLAT_ASSUME_YES=${OWLAT_ASSUME_YES:-0}" \
			"$OWLAT_SETUP_IMAGE" setup "$@"
		;;
	quickstart)
		# End-to-end: config wizard + docker up + convex deploy + env-set +
		# admin bootstrap + demo seed. Unlike `setup` (config-only), this
		# orchestrates the stack, so the container needs the Docker socket and
		# a way to reach the published Convex site port for the /seed/admin POST.
		#
		# On a Linux host (the blessed VPS install) the container joins the host
		# network with `--network host`, so `localhost:3210/3211` inside the
		# container is the host's published ports — this path is preserved
		# verbatim below.
		#
		# On Docker Desktop (macOS/Windows) containers run inside a Linux VM, so
		# `--network host` joins the VM's loopback, NOT the host's — localhost
		# would be unreachable and admin bootstrap + seed would fail. There we
		# run on the default bridge with `--add-host=host.docker.internal:host-gateway`
		# and pass OWLAT_LOCAL_HOST=host.docker.internal so the wizard reaches the
		# published host ports via host.docker.internal instead of localhost.
		# --legacy falls back to the complete bash wizard.
		for arg in "$@"; do
			if [[ "$arg" == "--legacy" ]]; then
				exec bash scripts/setup.sh "$@"
			fi
		done
		# Local-source installs: OWLAT_BUILD_LOCAL=1 makes quickstart write
		# OWLAT_VERSION=dev into .env and build the stack images from the
		# source tree; OWLAT_LOCAL_IMAGES=1 writes the same pin but uses
		# pre-pushed dev images as-is (built on the developer machine). Only
		# the flags are forwarded — OWLAT_VERSION itself must NOT leak into
		# the container, or compose interpolation would override .env.
		#
		# Detect Docker Desktop: any non-Linux kernel is Docker Desktop (macOS or
		# Windows), and on Linux hosts also honour a Docker Desktop engine
		# (some Linux dev machines run Docker Desktop rather than the native
		# daemon, where host networking is likewise VM-isolated).
		quickstart_docker_desktop=0
		if [[ "$(uname -s)" != "Linux" ]]; then
			quickstart_docker_desktop=1
		elif docker info --format '{{.OperatingSystem}}' 2>/dev/null | grep -qi 'docker desktop'; then
			quickstart_docker_desktop=1
		fi
		if [[ "$quickstart_docker_desktop" == "1" ]]; then
			exec docker run --rm $([ -t 1 ] && echo "-it") \
				--add-host=host.docker.internal:host-gateway \
				-v "$OWLAT_DIR:/opt/owlat" \
				-v /var/run/docker.sock:/var/run/docker.sock \
				${CONFIG_MOUNT_ARGS[@]+"${CONFIG_MOUNT_ARGS[@]}"} \
				-e "OWLAT_DIR=/opt/owlat" \
				-e "OWLAT_LOCAL_HOST=host.docker.internal" \
				-e "OWLAT_ASSUME_YES=${OWLAT_ASSUME_YES:-0}" \
				-e "OWLAT_PROGRESS=${OWLAT_PROGRESS:-}" \
				-e "OWLAT_BUILD_LOCAL=${OWLAT_BUILD_LOCAL:-0}" \
				-e "OWLAT_LOCAL_IMAGES=${OWLAT_LOCAL_IMAGES:-0}" \
				"$OWLAT_SETUP_IMAGE" quickstart "$@"
		fi
		exec docker run --rm $([ -t 1 ] && echo "-it") \
			--network host \
			-v "$OWLAT_DIR:/opt/owlat" \
			-v /var/run/docker.sock:/var/run/docker.sock \
			${CONFIG_MOUNT_ARGS[@]+"${CONFIG_MOUNT_ARGS[@]}"} \
			-e "OWLAT_DIR=/opt/owlat" \
			-e "OWLAT_ASSUME_YES=${OWLAT_ASSUME_YES:-0}" \
			-e "OWLAT_PROGRESS=${OWLAT_PROGRESS:-}" \
			-e "OWLAT_BUILD_LOCAL=${OWLAT_BUILD_LOCAL:-0}" \
			-e "OWLAT_LOCAL_IMAGES=${OWLAT_LOCAL_IMAGES:-0}" \
			"$OWLAT_SETUP_IMAGE" quickstart "$@"
		;;
	config)
		exec docker run --rm $([ -t 1 ] && echo "-it") \
			-v "$OWLAT_DIR:/opt/owlat" \
			${CONFIG_MOUNT_ARGS[@]+"${CONFIG_MOUNT_ARGS[@]}"} \
			"$OWLAT_SETUP_IMAGE" config "$@"
		;;
	feature)
		exec docker run --rm \
			-v "$OWLAT_DIR:/opt/owlat" \
			"$OWLAT_SETUP_IMAGE" feature "$@"
		;;
	env)
		exec docker run --rm \
			-v "$OWLAT_DIR:/opt/owlat" \
			"$OWLAT_SETUP_IMAGE" env "$@"
		;;
	start|up)
		# Activate docker-compose profiles for enabled features.
		COMPOSE_PROFILES=""
		if [[ -f "$OWLAT_DIR/docker-compose.override.yml" ]]; then
			COMPOSE_PROFILES=$(grep -oE 'x-owlat-profiles:.*' "$OWLAT_DIR/docker-compose.override.yml" | sed 's/.*\[//; s/\].*//; s/[[:space:]]*,[[:space:]]*/,/g; s/[[:space:]]//g' || true)
		fi
		export COMPOSE_PROFILES
		exec docker compose up -d "$@"
		;;
	stop|down)
		exec docker compose down "$@"
		;;
	restart)
		exec docker compose restart "$@"
		;;
	status|ps)
		exec docker compose ps "$@"
		;;
	logs)
		exec docker compose logs -f "$@"
		;;
	doctor)
		# New TS doctor inside the setup container; --legacy falls back to bash.
		for arg in "$@"; do
			if [[ "$arg" == "--legacy" ]]; then
				exec bash scripts/setup.sh doctor "$@"
			fi
		done
		exec docker run --rm \
			-v "$OWLAT_DIR:/opt/owlat" \
			"$OWLAT_SETUP_IMAGE" doctor "$@"
		;;
	shell|exec)
		svc="${1:-web}"
		shift || true
		exec docker compose exec "$svc" "${@:-sh}"
		;;
	backup)
		exec bash scripts/backup.sh "$@"
		;;
	backup-schedule)
		backup_schedule "$@"
		;;
	enable-backups)
		backup_schedule enable
		;;
	restore)
		exec bash scripts/restore.sh "$@"
		;;
	version)
		# Read version from the running web container env, or fall back to local .env / package.json
		if docker compose ps --format '{{.Service}}' 2>/dev/null | grep -q '^web$'; then
			v=$(docker compose exec -T web sh -c 'echo "$OWLAT_VERSION"' 2>/dev/null | tr -d '\r' || true)
			[[ -n "$v" && "$v" != "dev" ]] && { printf '%s\n' "$v"; exit 0; }
		fi
		if [[ -f package.json ]] && command -v node >/dev/null 2>&1; then
			node -p 'require("./package.json").version' 2>/dev/null && exit 0
		fi
		printf 'dev\n'
		;;
	upgrade|update)
		# Drive the in-app updater from the CLI. Parses --version FLAG.
		target_version=""
		while [[ $# -gt 0 ]]; do
			case "$1" in
				--version)
					target_version="$2"
					shift 2
					;;
				--version=*)
					target_version="${1#*=}"
					shift
					;;
				*)
					echo "Unknown upgrade flag: $1" >&2
					exit 2
					;;
			esac
		done

		# Resolve INSTANCE_SECRET from .env (needed to call updater sidecar)
		if [[ ! -f .env ]]; then
			echo "Error: .env not found — cannot call updater sidecar" >&2
			exit 1
		fi

		instance_secret=$(grep -E "^INSTANCE_SECRET=" .env | cut -d= -f2- | tr -d '"' | tr -d "'")
		if [[ -z "$instance_secret" ]]; then
			echo "Error: INSTANCE_SECRET not set in .env" >&2
			exit 1
		fi

		# Resolve target compose template
		if [[ -z "$target_version" ]]; then
			# Default: fetch the latest docker-compose-*.yml from GitHub Releases
			echo -e "${CYAN}${BOLD}[info]${RESET} Fetching latest release info…"
			latest=$(curl -fsSL "https://api.github.com/repos/wolvesdotink/owlat/releases/latest" \
				| grep -oE '"tag_name"[[:space:]]*:[[:space:]]*"v?[0-9]+\.[0-9]+\.[0-9]+"' \
				| head -1 \
				| sed -E 's/.*"v?([0-9]+\.[0-9]+\.[0-9]+)"/\1/')
			if [[ -z "$latest" ]]; then
				echo "Error: Could not parse latest release tag from GitHub" >&2
				exit 1
			fi
			target_version="$latest"
		fi

		compose_url="https://github.com/wolvesdotink/owlat/releases/download/v${target_version}/docker-compose-${target_version}.yml"

		echo -e "${CYAN}${BOLD}[info]${RESET} Target version: ${BOLD}${target_version}${RESET}"
		echo -e "${CYAN}${BOLD}[info]${RESET} Downloading compose template…"

		template=$(curl -fsSL "$compose_url") || {
			echo "Error: Could not fetch $compose_url" >&2
			echo "Check that v${target_version} exists on GitHub Releases." >&2
			exit 1
		}

		# Post to the local updater sidecar via docker network — simplest path
		# is to use a short-lived curl container on the same network.
		echo -e "${CYAN}${BOLD}[info]${RESET} Dispatching to updater sidecar…"
		payload=$(printf '%s' "$template" | jq -R -s '{composeTemplate: .}' 2>/dev/null) || {
			# Fallback without jq — base64 encode and decode server-side
			echo "Error: 'jq' is required. Install with: apt install jq" >&2
			exit 1
		}

		response=$(docker compose exec -T web curl -sf \
			-X POST "http://updater:3200/update" \
			-H "Content-Type: application/json" \
			-H "X-Instance-Secret: $instance_secret" \
			--max-time 600 \
			-d "$payload")

		if [[ -n "$response" ]]; then
			echo "$response" | jq . 2>/dev/null || echo "$response"
			echo ""
			echo -e "${GREEN}${BOLD}[ ok ]${RESET} Upgrade dispatched. Poll with: owlat status"
		else
			echo "Error: No response from updater" >&2
			exit 1
		fi
		;;
	help|--help|-h)
		show_help
		;;
	*)
		echo "Unknown subcommand: $cmd" >&2
		echo "" >&2
		show_help >&2
		exit 2
		;;
esac
