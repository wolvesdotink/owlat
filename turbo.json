{
	"$schema": "https://v2-9-14.turborepo.dev/schema.json",
	"globalEnv": ["NUXT_*", "CONVEX_*", "OWLAT_*", "POSTHOG_*"],
	"tasks": {
		"//#plugins:check": {
			"cache": false
		},
		"build": {
			"dependsOn": ["//#plugins:check", "^build"],
			"outputs": [".output/**", ".nuxt/**", "dist/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"typecheck": {
			"dependsOn": ["^build"]
		},
		"lint": {},
		"lint:fix": {},
		"codegen": {
			"cache": false
		},
		"deploy": {
			"cache": false,
			"dependsOn": ["//#plugins:check", "^build"]
		},
		"transit": {
			"dependsOn": ["^transit"]
		},
		"test": {
			"dependsOn": ["transit", "@owlat/plugin-kit#build"]
		},
		"test:coverage": {
			"dependsOn": ["transit", "@owlat/plugin-kit#build"],
			"outputs": ["coverage/**"]
		},
		"test:watch": {
			"cache": false,
			"persistent": true,
			"dependsOn": ["@owlat/plugin-kit#build"]
		}
	}
}
