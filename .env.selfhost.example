# ═══════════════════════════════════════════════════════════════════════════════
# Owlat Self-Hosted Configuration
# Audience: operators deploying the stack with Docker Compose. (Contributors
# hacking on Owlat itself with `bun run dev` want .env.example instead.)
# Copy this to .env and fill in the values before running docker compose up
# ═══════════════════════════════════════════════════════════════════════════════

# ── Convex Backend ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
INSTANCE_SECRET=

# Generated after first boot via: docker compose exec convex ./generate_admin_key.sh
# Required for deploying functions and setting Convex env vars
CONVEX_ADMIN_KEY=

# ── Public URLs ───────────────────────────────────────────────────────────────
# These must be reachable from the user's browser.
# NOTE: there is no CONVEX_SITE_URL knob here — it is a Convex BUILT-IN that the
# backend derives from NUXT_PUBLIC_CONVEX_SITE_URL (via CONVEX_SITE_ORIGIN on the
# convex container). `convex env set CONVEX_SITE_URL` is rejected
# (EnvVarNameForbidden), so set the public URL below and nowhere else.
NUXT_PUBLIC_CONVEX_URL=http://localhost:3210
NUXT_PUBLIC_CONVEX_SITE_URL=http://localhost:3211
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Convex function-runtime variables ────────────────────────────────────────
# These are read by Convex *functions*, not the compose containers. The
# `owlat quickstart` wizard generates/derives them and pushes them INTO the
# Convex deployment for you. If you are installing entirely by hand, set each one
# with `convex env set` after deploying functions (see the Option B sequence in
# docs/developer/self-hosting) — leaving them blank boots a backend that cannot
# log anyone in or send a single email.
#
# Auth + unsubscribe signing secrets. Generate each with: openssl rand -base64 32
BETTER_AUTH_SECRET=
UNSUBSCRIBE_SECRET=
# Public site URL for auth redirects (match NUXT_PUBLIC_SITE_URL above).
SITE_URL=http://localhost:3000
# In-cluster MTA address. REQUIRED for every send — including auth/system mail on
# resend/ses installs — or sending hard-throws "No system email transport configured".
MTA_API_URL=http://mta:3100
# Default sender identity for system mail (invitations, password resets, …).
DEFAULT_FROM_EMAIL=noreply@example.com
DEFAULT_FROM_NAME=Owlat
DEFAULT_FROM_DOMAIN=example.com

# ── Operating mode: delivery provider + active services ─────────────────────
# The built-in MTA is now an opt-in service (the `mta` compose profile). For the
# default self-host the MTA is both the delivery provider and the inbound MX, so
# keep `mta` in COMPOSE_PROFILES. Switch to a third-party provider
# (EMAIL_PROVIDER=resend|ses|smtp, with its credentials below) and drop `mta`
# here to stop running it. Add other profiles (personal-mail, external-mail, ai, clamav)
# as you enable those features — the setup CLI/wizard manages this for you.
EMAIL_PROVIDER=mta
COMPOSE_PROFILES=mta

# ── MTA Configuration (only when EMAIL_PROVIDER=mta or postbox/inbox enabled) ──
# Generate with: openssl rand -base64 32
MTA_API_KEY=
MTA_WEBHOOK_SECRET=

# Must match your server's rDNS PTR record
EHLO_HOSTNAME=mail.example.com

# Domain for VERP bounce return-path addresses
RETURN_PATH_DOMAIN=bounces.example.com

# Secret that signs the VERP bounce token (BATV/HMAC) so forged DSNs cannot
# poison the suppression list. Generate with `openssl rand -base64 32`.
# Leave unset to keep legacy unsigned tokens.
# BOUNCE_VERP_KEY=

# Comma-separated IP addresses for sending pools
IP_POOLS_TRANSACTIONAL=127.0.0.1
IP_POOLS_CAMPAIGN=127.0.0.1

# JSON object: {"example.com":{"selector":"s1","privateKey":"-----BEGIN RSA..."}}
DKIM_KEYS={}

# MTA tuning (optional)
WORKER_CONCURRENCY=50
MTA_LOG_LEVEL=info
# Outbound TLS posture for direct-MX delivery (RFC 7435/8461/9325):
#   opportunistic (default), require, or require-verified.
# require-verified can bounce mail to receivers with a broken/self-signed
# certificate. Per-domain overrides: the master-key-protected /outbound-tls API.
OUTBOUND_TLS_MODE=opportunistic

# ── Generic SMTP relay (only when EMAIL_PROVIDER=smtp) ───────────────────────
# Send through any SMTP submission host — Mailgun, Postmark, SendGrid, Brevo, or
# a custom relay. The relay owns the sending IPs and DKIM signing, so configure
# SPF/DKIM for your From-domain in the relay's dashboard (not via the MTA DNS
# bundle). Drop `mta` from COMPOSE_PROFILES when you rely on a relay.
# SMTP_RELAY_HOST=smtp.mailgun.org
# SMTP_RELAY_PORT=587           # 587 = STARTTLS (default); 465 = implicit TLS
# SMTP_RELAY_SECURE=false       # "true" only for implicit TLS on 465
# SMTP_RELAY_USERNAME=
# SMTP_RELAY_PASSWORD=

# ── Redis (internal-only; password is defense-in-depth) ─────────────────────
# REDIS_PASSWORD=change-me

# ── Port Overrides (optional) ────────────────────────────────────────────────
# Convex, the MTA HTTP API, and the dashboard bind to 127.0.0.1 by default;
# Redis and ClamAV publish no host port at all. Front the stack with the
# `tls` profile (Caddy) for remote access. CONVEX_BIND=0.0.0.0 exposes the
# backend raw — only do that behind your own firewall/proxy.
# CONVEX_BIND=127.0.0.1
# CONVEX_PORT=3210
# CONVEX_SITE_PORT=3211
# DASHBOARD_PORT=6791   # requires: docker compose --profile dashboard up -d
# WEB_PORT=3000
# MTA_HTTP_PORT=3100
# MTA_SMTP_PORT=25
# IMAP_PORT=993

# ── PostHog Analytics (optional) ─────────────────────────────────────────────
# NUXT_PUBLIC_POSTHOG_API_KEY=
# NUXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Local LLM / Ollama (optional, --profile dev) ──────────────────────────────
# Run AI inference on your own hardware instead of a hosted provider. Bring up
# the bundled `ollama` service with: docker compose --profile dev up -d ollama
# It is reachable only on the internal Docker network as ollama:11434 (no host
# port). Pin the image tag here if you don't want :latest:
# OLLAMA_VERSION=latest
#
# Then point the agent pipeline at it. These are Convex *function* env vars —
# set them on the backend with `convex env set` (not in this compose .env):
#   LLM_PROVIDER=ollama
#   LLM_BASE_URL=http://ollama:11434/v1   # auto-resolved when LLM_PROVIDER=ollama
# No LLM_API_KEY is required for Ollama.
#
# EMBEDDINGS (local-by-default plane): retrieval / knowledge graph / semantic
# search resolve embeddings INDEPENDENTLY of the language provider, so they work
# even under a language provider with no embeddings API (e.g. Anthropic). Point
# them at a local OpenAI-compatible /embeddings sidecar — again Convex env vars:
#   LOCAL_EMBEDDING_BASE_URL=http://ollama:11434/v1
#   LOCAL_EMBEDDING_MODEL=nomic-embed-text
# NOTE: the local model's native vector width must match the fixed vector index
# (EMBEDDING_DIMENSIONS, 1536). nomic-embed-text is 768-dim — either run a
# 1536-dim model or change EMBEDDING_DIMENSIONS and re-index; the dimension guard
# rejects a mismatched vector rather than silently corrupting search.

# ── Deployment Mode ──────────────────────────────────────────────────────────
# Tells the web app whether to show the self-host onboarding banner or hide
# hosted-only UI (billing, upgrade prompts). Leave as "selfhost" unless you're
# running the managed cloud offering.
OWLAT_DEPLOYMENT_MODE=selfhost

# ── Install Directory (required for in-app updates) ──────────────────────────
# Absolute path to this repo on the host. The updater sidecar mounts this to
# write compose templates and run `docker compose pull && up -d`. Defaults to
# the current directory (works with `docker compose up -d` from the repo root).
# OWLAT_INSTALL_DIR=/opt/owlat

# ── Version Metadata (set by release pipeline — do not edit manually) ────────
# OWLAT_VERSION=dev
# OWLAT_GIT_SHA=unknown
# OWLAT_BUILD_DATE=unknown
