# ============================================================
# Owlat — LOCAL DEVELOPMENT env (for working on Owlat itself)
# ============================================================
# Audience: contributors running `bun run dev` / `bun run setup` against a
# local Convex backend (or a hosted convex.cloud deployment). For a
# self-hosted Docker Compose deployment, copy .env.selfhost.example instead —
# the two templates are NOT interchangeable.

# Nuxt Public Configuration
# The Convex deployment URL (local backend binds 3210; e.g. a hosted
# deployment would be https://your-deployment.convex.cloud)
NUXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# The Convex HTTP site URL for auth callbacks and API routes (local: 3211)
NUXT_PUBLIC_CONVEX_SITE_URL=http://localhost:3211

# The public site URL for your application
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# PostHog product analytics (optional — app works without it)
NUXT_PUBLIC_POSTHOG_API_KEY=
NUXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ============================================================
# Convex Environment Variables
# ============================================================
# These variables are set in the Convex deployment settings, not in this file.
# They are documented here for reference.
# See: apps/docs/developer/environment-variables.md

# --- Auth ---
# BETTER_AUTH_SECRET=your-secret-key-here
# SITE_URL=http://localhost:3000

# --- Dev shortcuts ---
# Set to enable `/seed/demo`, `/dev/reset`, and Force Verify Domain. Leave
# unset on any production deployment.
#   npx convex env set OWLAT_DEV_MODE true
# OWLAT_DEV_MODE=true

# --- Email Provider ---
# EMAIL_PROVIDER=mta                     # "mta" (default), "ses", "resend", or "smtp"

# AWS SES (required if EMAIL_PROVIDER=ses)
# AWS_SES_REGION=eu-west-1
# AWS_SES_ACCESS_KEY_ID=AKIA...
# AWS_SES_SECRET_ACCESS_KEY=...
# Optional: SES Configuration Set applied to every send so bounce/complaint/
# delivery feedback (SNS → /webhooks/ses) is attributed to the originating send.
# SES_CONFIGURATION_SET=owlat-ses
# Required to enable the /webhooks/ses feedback loop: the exact SNS topic ARN
# authorized to deliver feedback. A valid SNS signature only proves AWS
# authorship, so Owlat rejects any envelope from a different topic and keeps the
# endpoint closed (503) until this is set.
# SES_SNS_TOPIC_ARN=arn:aws:sns:eu-west-1:123456789012:owlat-ses-feedback

# Resend (required if EMAIL_PROVIDER=resend)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_WEBHOOK_SECRET=whsec_...

# Generic SMTP relay (required if EMAIL_PROVIDER=smtp) — works with Mailgun,
# Postmark, SendGrid, Brevo or any custom SMTP submission host. The relay owns
# the sending IPs and DKIM signing, so set up SPF/DKIM for your From-domain in
# the relay's dashboard (not through the built-in MTA DNS bundle).
# SMTP_RELAY_HOST=smtp.mailgun.org
# SMTP_RELAY_PORT=587                    # 587 = STARTTLS (default); 465 = implicit TLS
# SMTP_RELAY_SECURE=false                # "true" only for implicit TLS on 465
# SMTP_RELAY_USERNAME=postmaster@mg.example.com
# SMTP_RELAY_PASSWORD=...

# Common email configuration
# DEFAULT_FROM_EMAIL=noreply@example.com
# DEFAULT_FROM_NAME=Owlat
# DEFAULT_FROM_DOMAIN=mail.owlat.app
# CONVEX_SITE_URL=https://your-deployment.convex.site
# UNSUBSCRIBE_SECRET=your-unsubscribe-secret

# --- Analytics (PostHog) ---
# POSTHOG_API_KEY=phc_...
# POSTHOG_HOST=https://eu.i.posthog.com

# --- Translations (AI) ---
# OPENROUTER_API_KEY=sk-or-...           # Primary provider
# OPENAI_API_KEY=sk-...                  # Fallback provider

# --- CORS ---
# Allowed origins for CORS on private API endpoints (comma-separated)
# ALLOWED_ORIGINS=https://app.owlat.app,http://localhost:3000
