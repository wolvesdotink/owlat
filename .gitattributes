# Normalize line endings so shell scripts always check out with LF,
# regardless of the contributor's OS or git core.autocrlf setting.
# On Git-for-Windows (default core.autocrlf=true) *.sh files would otherwise
# get CRLF and fail with `bad interpreter: /usr/bin/env bash^M`.
* text=auto eol=lf

# Shell scripts must always be LF.
*.sh text eol=lf
scripts/owlat text eol=lf
install.sh text eol=lf

# Binary assets: never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.woff binary
*.woff2 binary
*.pdf binary
*.wasm binary

# Keep the lockfile byte-exact.
bun.lock -text

# Sealed-mail interop fixtures are checked in AS BYTES: RFC 5322 messages are
# CRLF and detached PGP signatures / body hashes are computed over exact bytes,
# so git must never EOL-normalize them (the blanket `* text=auto eol=lf` above
# would silently corrupt every signature). Exempt the whole corpus.
apps/api/fixtures/sealed-mail/** -text
# The A5 ARC interop fixtures live at the repo-root corpus. RFC 8617 ARC seals /
# AMS body hashes are computed over exact CRLF bytes, so these must never be
# EOL-normalized either.
fixtures/sealed-mail/** -text
# The C0 inbound-replay corpus slice is checked in AS BYTES: RFC 5322 messages
# are CRLF and the harness diffs the two parse stacks over exact bytes, so git
# must never EOL-normalize them.
apps/mta/src/tools/__fixtures__/replay-corpus/** -text
# The IMAP-shaped replay slice (piece CI1, mail-sync ingest cutover) is the same
# byte-exact deal: CRLF RFC 5322 messages diffed over exact bytes.
apps/mta/src/tools/__fixtures__/imap-corpus/** -text
