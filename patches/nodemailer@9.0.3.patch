diff --git a/lib/smtp-connection/index.js b/lib/smtp-connection/index.js
--- a/lib/smtp-connection/index.js
+++ b/lib/smtp-connection/index.js
@@ -1069,6 +1069,12 @@
             opts.servername = this.servername;
         }
 
+        // Optional policy verifier that runs after the TLS handshake but before
+        // SMTP resumes. Unlike checkServerIdentity, this also runs when ordinary
+        // PKIX verification is disabled (required for DANE-EE authentication).
+        const verifyPeerCertificate = opts.verifyPeerCertificate;
+        delete opts.verifyPeerCertificate;
+
         // Remove all listeners from the plain socket to allow proper garbage
         // collection. Used on both the TLS-success path and the synchronous
         // tls.connect() throw path; either way the plain socket is done.
@@ -1085,6 +1091,20 @@
         // tls.connect is not an asynchronous function however it may still throw errors and requires to be wrapped with try/catch
         try {
             this._socket = tls.connect(opts, () => {
+                if (typeof verifyPeerCertificate === 'function') {
+                    let verificationError;
+                    try {
+                        verificationError = verifyPeerCertificate(this._socket);
+                    } catch (err) {
+                        verificationError = err;
+                    }
+                    if (verificationError) {
+                        this.upgrading = false;
+                        removePlainSocketListeners();
+                        this._socket.destroy();
+                        return callback(verificationError);
+                    }
+                }
                 this.secure = true;
                 this.upgrading = false;
                 this._socket.on('data', this._onSocketData);
