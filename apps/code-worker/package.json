{
	"name": "@owlat/code-worker",
	"version": "0.1.0",
	"private": true,
	"license": "MIT",
	"homepage": "https://owlat.app",
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"start": "node dist/index.js",
		"lint": "oxlint --config ../../oxlintrc.json --ignore-pattern '**/__tests__/**' src",
		"lint:fix": "oxlint --config ../../oxlintrc.json --ignore-pattern '**/__tests__/**' src --fix",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage --passWithNoTests"
	},
	"dependencies": {
		"convex": "^1.34.0",
		"@octokit/rest": "^21.0.0",
		"execa": "^9.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"tsx": "^4.19.0",
		"typescript": "^5.9.0",
		"vitest": "catalog:"
	}
}
