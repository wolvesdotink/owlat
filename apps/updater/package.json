{
	"name": "@owlat/updater",
	"version": "0.3.3",
	"private": true,
	"license": "Apache-2.0",
	"homepage": "https://owlat.app",
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"start": "node dist/index.js",
		"lint": "oxlint --config ../../oxlintrc.json --ignore-pattern '**/__tests__/**' src",
		"lint:fix": "oxlint --config ../../oxlintrc.json --ignore-pattern '**/__tests__/**' src --fix",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage --passWithNoTests"
	},
	"dependencies": {},
	"devDependencies": {
		"@types/node": "^26.0.1",
		"tsx": "^4.19.0",
		"typescript": "^6.0.3",
		"vitest": "catalog:"
	}
}
