# owlat-mta Environment Variables
#
# Every key the MTA reads (apps/mta/src/config.ts loadConfig + a few runtime
# helpers). Required keys have no default and the process refuses to start
# without them; optional keys show their default. The check-env-example test
# (src/__tests__/config.test.ts) asserts this file stays in sync with config.ts.

# ── Required ──────────────────────────────────────────────────────────────
# API authentication (shared between Convex and MTA)
MTA_API_KEY=your-secure-api-key-here
# Seals transport secrets at rest (DKIM private keys, relay credentials). Must be
# >= 32 bytes or the process refuses to start. The installer generates it; keep
# it STABLE across restarts (rotating it strands already-sealed values). Distinct
# from MTA_API_KEY/MTA_WEBHOOK_SECRET. Generate with `openssl rand -hex 32`.
MTA_SECRET=your-32-byte-plus-mta-secret-here
# SMTP identity (EHLO must match the rDNS PTR record). Must be a public FQDN —
# 'localhost', a bare hostname, or a raw IP are rejected at startup.
EHLO_HOSTNAME=mta1.owlat.com
# Per-IP EHLO overrides for multi-IP deployments (JSON: bind IP → FQDN). Each
# sending IP needs its own PTR, so announce each IP's own PTR-matching name.
# Unlisted IPs fall back to EHLO_HOSTNAME. Leave unset for single-IP setups.
# EHLO_HOSTNAMES={"1.2.3.4":"mail1.owlat.com","5.6.7.8":"mail2.owlat.com"}
# Additional provider-default PTR suffixes to flag as reputationally poor.
# Comma-separated DNS suffixes only; no regular expressions are evaluated.
# MTA_GENERIC_PTR_SUFFIXES=static.example-vps.net,customer.example-host.net
# LAB ONLY: bypass FCrDNS quarantine while retaining the failed status in health/UI.
MTA_ALLOW_UNVERIFIED_FCRDNS=false
RETURN_PATH_DOMAIN=bounces.owlat.com
# Required secret that signs the VERP return-path token (BATV/HMAC). Only
# bounce DSNs addressed to a token the MTA actually signed are attributed, so a
# forged DSN cannot poison the suppression list (RFC 5321: anyone may submit a
# DSN). Generate a long random value, e.g. `openssl rand -base64 32`, and keep
# it stable across restarts.
BOUNCE_VERP_KEY=replace-with-openssl-rand-base64-32
# Convex webhook callback target + HMAC secret
CONVEX_SITE_URL=https://your-deployment.convex.site
MTA_WEBHOOK_SECRET=your-webhook-secret-here
# TLS-RPT (RFC 8460) reporting address published in `_smtp._tls` rua=. When set
# (same value as the Convex MTA_TLSRPT_RUA), inbound reports to it are caught by
# the TLS-RPT system route and forwarded (HMAC-signed) to /webhooks/mta-tls-report.
# Leave unset if you don't collect inbound TLS reports.
# MTA_TLSRPT_RUA=mailto:tls-reports@your-domain.com
# Sending IP pools (comma-separated; at least one IP each)
IP_POOLS_TRANSACTIONAL=1.2.3.4
IP_POOLS_CAMPAIGN=5.6.7.8,9.10.11.12

# ── HTTP / SMTP ports ─────────────────────────────────────────────────────
PORT=3100
# Inbound SMTP for bounce processing (port 25 requires root/CAP_NET_BIND)
BOUNCE_PORT=25
# SMTP submission (587, STARTTLS) — enable to accept authenticated client submissions
SUBMISSION_PORT=587
SUBMISSION_ENABLED=false
# Implicit-TLS submission (465) — RFC 8314 §3.3/§7.3-PREFERRED transport: the
# whole connection is wrapped in TLS, so AUTH can never be offered in plaintext.
# Reuses SUBMISSION_TLS_CERT/KEY. Enable alongside or instead of 587.
SUBMISSION_IMPLICIT_TLS_PORT=465
SUBMISSION_IMPLICIT_TLS_ENABLED=false
# TLS is MANDATORY when either submission listener is enabled — the process
# refuses to start without both cert and key (RFC 8314 §3.3; STARTTLS is also
# required before AUTH on 587).
# SUBMISSION_TLS_CERT=        # PEM string; serves STARTTLS (587) + implicit TLS (465)
# SUBMISSION_TLS_KEY=
# Brute-force hardening for the AUTH paths
SUBMISSION_MAX_CONNECTIONS_PER_IP=10
SUBMISSION_MAX_CLIENTS=200
SUBMISSION_MAX_AUTH_FAILURES_PER_IP=10

# ── Infrastructure ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Multi-instance server ID (defaults to hostname)
# MTA_SERVER_ID=mta1
# Worker concurrency (parallel group processing)
WORKER_CONCURRENCY=50
# Max wall-clock age (ms) a message keeps being retried before the MTA gives up
# and emits a terminal expired-bounce. RFC 5321 §4.5.4.1 recommends 4-5 days.
# Measured from first enqueue, so it survives defer re-queues. Default: 4 days.
MAX_MESSAGE_AGE_MS=345600000
# DKIM keys (JSON: {"domain":{"selector":"s1","privateKey":"-----BEGIN RSA PRIVATE KEY-----\n..."}})
DKIM_KEYS={}

# Outbound TLS posture for direct-MX delivery (RFC 7435/8461/9325):
#   opportunistic   - encrypt when STARTTLS is offered, never fail delivery
#                     (default; byte-identical to prior behaviour)
#   require         - require the STARTTLS upgrade (certificate not verified)
#   require-verified - require TLS AND verify the certificate (can bounce mail to
#                      receivers with broken/self-signed TLS)
# Per-domain overrides are managed via the master-key-protected /outbound-tls API.
OUTBOUND_TLS_MODE=opportunistic

# ── DANE / TLSA at send time (RFC 7672) ───────────────────────────────────
# DANE_MODE is one of off / report / enforce (default: report). In report and
# enforce the sender looks up each recipient MX's DNSSEC-authenticated TLSA RRset
# (_25._tcp.<mx>) and evaluates the MX certificate against it:
#   report   (default) EMIT the TLS-RPT result (success / validation-failure under
#            the tlsa policy) but never require TLS or bounce — delivery proceeds
#            on the normal opportunistic/MTA-STS decision (observability only, D6);
#   enforce  a require-TLS floor that supersedes MTA-STS — a non-matching
#            certificate defers the message (never falls back to cleartext).
# DANE is only safe with a VALIDATING resolver: the DoH resolver's DNSSEC AD bit
# is trusted, and an answer without AD is treated as "no TLSA". A TLSA lookup that
# cannot be completed (SERVFAIL / timeout) defers the message under enforce (a
# no-op under report) rather than downgrading. Running a local validating resolver
# is the recommended production configuration.
# DANE_MODE=report
# Needed for report/enforce to run — a DoH (RFC 8484 JSON) validating resolver.
# WITHOUT it DANE is inert in every mode, so a fresh install behaves exactly as
# before. Must be https:// (http:// is accepted only for a loopback resolver): the
# AD bit is only trustworthy over a channel an on-path attacker cannot forge.
# DANE_RESOLVER_URL=https://127.0.0.1:8443/dns-query

# ── SMTP connection pool ──────────────────────────────────────────────────
SMTP_POOL_MAX_PER_HOST=3
SMTP_POOL_IDLE_TIMEOUT_MS=30000
SMTP_POOL_MAX_AGE_MS=300000
# Deliveries carried over ONE reused MX socket (true RSET socket reuse) before a
# clean QUIT + reconnect. ~100 default.
SMTP_POOL_MAX_MESSAGES_PER_CONNECTION=100
# Global max connections per MX host across all instances
SMTP_POOL_GLOBAL_MAX_PER_HOST=10
# Rolling-upgrade safety gate. Keep legacy-v0 throughout the software rollout.
# After ALL old MTA nodes are drained and mta:pool:global:* keys have expired,
# switch the whole stopped fleet to leases-v1 before restarting it.
SMTP_POOL_COORDINATION_PROTOCOL=legacy-v0

# ── Per-organization send limits ──────────────────────────────────────────
ORG_DEFAULT_DAILY_LIMIT=50000
ORG_DEFAULT_HOURLY_LIMIT=5000

# ── Content screening ─────────────────────────────────────────────────────
CONTENT_SCREENING_ENABLED=true
CONTENT_MAX_SIZE_KB=500
# Optional rspamd HTTP endpoint + reject threshold for spam scoring
# RSPAMD_URL=http://rspamd:11333
RSPAMD_REJECT_THRESHOLD=15
# ClamAV (attachment scanning) — read by the scan route
# CLAMAV_HOST=clamav
# CLAMAV_PORT=3310

# ── Delivery log (Redis streams) ──────────────────────────────────────────
DELIVERY_LOG_MAX_LEN=100000
DELIVERY_LOG_TTL_HOURS=72
# Max entries in the webhook dead-letter queue
WEBHOOK_DLQ_MAX_SIZE=10000

# ── Bounce SMTP server hardening ──────────────────────────────────────────
# BOUNCE_TLS_CERT=            # PEM string; enables STARTTLS on the bounce server
# BOUNCE_TLS_KEY=
BOUNCE_MAX_CONNECTIONS_PER_IP=10
BOUNCE_MAX_CLIENTS=200
BOUNCE_TARPIT_ENABLED=true
BOUNCE_TARPIT_DELAY_MS=5000
# Idle timeout (ms) for the bounce/MX listener command + DATA phases (preserves smtp-server's 60s socketTimeout)
BOUNCE_SOCKET_TIMEOUT_MS=60000
# Validate SPF on inbound bounce mail
INBOUND_SPF_ENABLED=true
# Verify DKIM (RFC 6376) on inbound mail; verdict recorded as dkimResult
INBOUND_DKIM_ENABLED=true
# Evaluate DMARC (RFC 7489) on inbound mail; verdict recorded as dmarcResult.
# A quarantine/reject DMARC fail routes the message to the recipient's Spam folder.
INBOUND_DMARC_ENABLED=true
# Verify the ARC chain (RFC 8617) on inbound mail (Sealed Mail A5). When a TRUSTED
# forwarder's ARC seal attests the original passed, the Convex delivery path
# rescues the DMARC fail (mailing-list / forwarded mail stays out of Spam). The
# trusted-forwarder list is edited in the app (Settings → Delivery), not here.
INBOUND_ARC_ENABLED=true

# ── Reputation feeds ──────────────────────────────────────────────────────
# Google Postmaster Tools v2 user OAuth (all three are required together).
# Grant both read scopes when creating the offline refresh token:
# https://www.googleapis.com/auth/postmaster.domain
# https://www.googleapis.com/auth/postmaster.traffic.readonly
# The refresh token is a secret; never expose it to the browser or logs.
# GOOGLE_POSTMASTER_CLIENT_ID=
# GOOGLE_POSTMASTER_CLIENT_SECRET=
# GOOGLE_POSTMASTER_REFRESH_TOKEN=
# Optional Abusix Guardian Mail namespace key. Abusix remains warning-only.
# ABUSIX_DNSBL_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
