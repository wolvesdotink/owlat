# owlat-mta Environment Variables
#
# Every key the MTA reads (apps/mta/src/config.ts loadConfig + a few runtime
# helpers). Required keys have no default and the process refuses to start
# without them; optional keys show their default. The check-env-example test
# (src/__tests__/config.test.ts) asserts this file stays in sync with config.ts.

# ── Required ──────────────────────────────────────────────────────────────
# API authentication (shared between Convex and MTA)
MTA_API_KEY=your-secure-api-key-here
# SMTP identity (EHLO must match the rDNS PTR record). Must be a public FQDN —
# 'localhost', a bare hostname, or a raw IP are rejected at startup.
EHLO_HOSTNAME=mta1.owlat.com
# Per-IP EHLO overrides for multi-IP deployments (JSON: bind IP → FQDN). Each
# sending IP needs its own PTR, so announce each IP's own PTR-matching name.
# Unlisted IPs fall back to EHLO_HOSTNAME. Leave unset for single-IP setups.
# EHLO_HOSTNAMES={"1.2.3.4":"mail1.owlat.com","5.6.7.8":"mail2.owlat.com"}
RETURN_PATH_DOMAIN=bounces.owlat.com
# Secret key that signs the VERP return-path token (BATV/HMAC). When set, only
# bounce DSNs addressed to a token the MTA actually signed are attributed, so a
# forged DSN cannot poison the suppression list (RFC 5321: anyone may submit a
# DSN). Leave unset to keep the legacy unsigned tokens. Generate a long random
# value, e.g. `openssl rand -base64 32`, and keep it stable across restarts.
# BOUNCE_VERP_KEY=
# Convex webhook callback target + HMAC secret
CONVEX_SITE_URL=https://your-deployment.convex.site
MTA_WEBHOOK_SECRET=your-webhook-secret-here
# Sending IP pools (comma-separated; at least one IP each)
IP_POOLS_TRANSACTIONAL=1.2.3.4
IP_POOLS_CAMPAIGN=5.6.7.8,9.10.11.12

# ── HTTP / SMTP ports ─────────────────────────────────────────────────────
PORT=3100
# Inbound SMTP for bounce processing (port 25 requires root/CAP_NET_BIND)
BOUNCE_PORT=25
# SMTP submission (587, STARTTLS) — enable to accept authenticated client submissions
SUBMISSION_PORT=587
SUBMISSION_ENABLED=false
# Implicit-TLS submission (465) — RFC 8314 §3.3/§7.3-PREFERRED transport: the
# whole connection is wrapped in TLS, so AUTH can never be offered in plaintext.
# Reuses SUBMISSION_TLS_CERT/KEY. Enable alongside or instead of 587.
SUBMISSION_IMPLICIT_TLS_PORT=465
SUBMISSION_IMPLICIT_TLS_ENABLED=false
# TLS is MANDATORY when either submission listener is enabled — the process
# refuses to start without both cert and key (RFC 8314 §3.3; STARTTLS is also
# required before AUTH on 587).
# SUBMISSION_TLS_CERT=        # PEM string; serves STARTTLS (587) + implicit TLS (465)
# SUBMISSION_TLS_KEY=
# Brute-force hardening for the AUTH paths
SUBMISSION_MAX_CONNECTIONS_PER_IP=10
SUBMISSION_MAX_CLIENTS=200
SUBMISSION_MAX_AUTH_FAILURES_PER_IP=10

# ── Infrastructure ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Multi-instance server ID (defaults to hostname)
# MTA_SERVER_ID=mta1
# Worker concurrency (parallel group processing)
WORKER_CONCURRENCY=50
# Max wall-clock age (ms) a message keeps being retried before the MTA gives up
# and emits a terminal expired-bounce. RFC 5321 §4.5.4.1 recommends 4-5 days.
# Measured from first enqueue, so it survives defer re-queues. Default: 4 days.
MAX_MESSAGE_AGE_MS=345600000
# DKIM keys (JSON: {"domain":{"selector":"s1","privateKey":"-----BEGIN RSA PRIVATE KEY-----\n..."}})
DKIM_KEYS={}

# ── SMTP connection pool ──────────────────────────────────────────────────
SMTP_POOL_MAX_PER_HOST=3
SMTP_POOL_IDLE_TIMEOUT_MS=30000
SMTP_POOL_MAX_AGE_MS=300000
# Global max connections per MX host across all instances
SMTP_POOL_GLOBAL_MAX_PER_HOST=10

# ── Per-organization send limits ──────────────────────────────────────────
ORG_DEFAULT_DAILY_LIMIT=50000
ORG_DEFAULT_HOURLY_LIMIT=5000

# ── Content screening ─────────────────────────────────────────────────────
CONTENT_SCREENING_ENABLED=true
CONTENT_MAX_SIZE_KB=500
# Optional rspamd HTTP endpoint + reject threshold for spam scoring
# RSPAMD_URL=http://rspamd:11333
RSPAMD_REJECT_THRESHOLD=15
# ClamAV (attachment scanning) — read by the scan route
# CLAMAV_HOST=clamav
# CLAMAV_PORT=3310

# ── Delivery log (Redis streams) ──────────────────────────────────────────
DELIVERY_LOG_MAX_LEN=100000
DELIVERY_LOG_TTL_HOURS=72
# Max entries in the webhook dead-letter queue
WEBHOOK_DLQ_MAX_SIZE=10000

# ── Bounce SMTP server hardening ──────────────────────────────────────────
# BOUNCE_TLS_CERT=            # PEM string; enables STARTTLS on the bounce server
# BOUNCE_TLS_KEY=
BOUNCE_MAX_CONNECTIONS_PER_IP=10
BOUNCE_MAX_CLIENTS=200
BOUNCE_TARPIT_ENABLED=true
BOUNCE_TARPIT_DELAY_MS=5000
# Validate SPF on inbound bounce mail
INBOUND_SPF_ENABLED=true
# Verify DKIM (RFC 6376) on inbound mail; verdict recorded as dkimResult
INBOUND_DKIM_ENABLED=true
# Evaluate DMARC (RFC 7489) on inbound mail; verdict recorded as dmarcResult.
# A quarantine/reject DMARC fail routes the message to the recipient's Spam folder.
INBOUND_DMARC_ENABLED=true

# ── Reputation feeds ──────────────────────────────────────────────────────
# Google Postmaster Tools service-account credentials JSON
# GOOGLE_POSTMASTER_CREDENTIALS=

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
