{
	"$schema": "https://raw.githubusercontent.com/nicovrc/tauri2/schema.json",
	"productName": "Owlat",
	"identifier": "com.owlat.desktop",
	"build": {
		"beforeBuildCommand": "cd ../../apps/web && bun run generate:desktop",
		"beforeDevCommand": "cd ../../apps/web && bun run dev:desktop",
		"devUrl": "http://localhost:3000",
		"frontendDist": "../../web/.output/public"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Owlat",
				"width": 1200,
				"height": 800,
				"minWidth": 800,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false,
				"decorations": true,
				"titleBarStyle": "Overlay",
				"hiddenTitle": true,
				"transparent": true,
				"visible": true
			}
		],
		"macOSPrivateApi": true,
		"security": {
			"csp": "default-src 'self' tauri: ipc:; connect-src 'self' https://* wss://* http://localhost:* ws://localhost:* http://127.0.0.1:* ws://127.0.0.1:*; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; font-src 'self' data: https:; frame-src 'self' blob:"
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	},
	"plugins": {
		"shell": {
			"open": true
		},
		"deep-link": {
			"desktop": {
				"schemes": ["owlat", "mailto"]
			}
		},
		"updater": {
			"endpoints": [
				"https://github.com/wolvesdotink/owlat/releases/latest/download/latest.json"
			],
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM1RUJEMjdGRjExN0ZCRUUKUldUdSt4ZnhmOUxyeFJZU0x1Um9wajVNWHJqYy82a3ZZMFdJZHZRdDBmVmV1UFB4d0JuQ0E0TGQK"
		}
	}
}
