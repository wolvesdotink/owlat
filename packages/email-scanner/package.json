{
	"name": "@owlat/email-scanner",
	"version": "0.3.1",
	"private": true,
	"license": "Apache-2.0",
	"homepage": "https://owlat.app",
	"description": "Email security scanner — malicious content, attachment, and URL reputation scanning",
	"type": "module",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./content": {
			"types": "./src/content/index.ts",
			"import": "./src/content/index.ts"
		},
		"./files": {
			"types": "./src/files/index.ts",
			"import": "./src/files/index.ts"
		},
		"./clamav": {
			"types": "./src/clamav/index.ts",
			"import": "./src/clamav/index.ts"
		},
		"./urls": {
			"types": "./src/urls/index.ts",
			"import": "./src/urls/index.ts"
		}
	},
	"scripts": {
		"lint": "oxlint --config ../../oxlintrc.json src",
		"lint:fix": "oxlint --config ../../oxlintrc.json src --fix",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"dependencies": {
		"@owlat/shared": "workspace:*"
	}
}
