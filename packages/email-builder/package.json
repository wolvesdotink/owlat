{
	"name": "@owlat/email-builder",
	"version": "0.2.1",
	"private": true,
	"license": "Apache-2.0",
	"homepage": "https://owlat.app",
	"type": "module",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
