	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"happy-dom": "^20.8.4",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"vue-tsc": "catalog:"
	},
	"peerDependencies": {
		"@owlat/ui": "workspace:*",
		"@lucide/vue": "^1.0.0",
		"vue": "^3.5.0",
		"vue-draggable-plus": "^0.6.0"
	}
