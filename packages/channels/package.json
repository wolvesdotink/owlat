{
	"name": "@owlat/channels",
	"version": "0.3.0",
	"private": true,
	"license": "Apache-2.0",
	"homepage": "https://owlat.app",
	"description": "Owlat communication channel adapters — email, SMS, WhatsApp, webhooks, native chat",
	"type": "module",
	"main": "./src/index.ts",
