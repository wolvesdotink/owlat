{
	"name": "@owlat/email-renderer",
	"version": "0.3.1",
	"private": true,
	"license": "Apache-2.0",
	"homepage": "https://owlat.app",
	"type": "module",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"scripts": {
		"lint": "oxlint --config ../../oxlintrc.json src",
		"lint:fix": "oxlint --config ../../oxlintrc.json src --fix",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"preview": "bun src/preview/generate.ts",
		"preview:open": "bun src/preview/generate.ts --open"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@types/sanitize-html": "^2.13.0",
		"@vitest/coverage-v8": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"dependencies": {
		"@owlat/shared": "workspace:*",
		"sanitize-html": "^2.13.0"
	}
}
