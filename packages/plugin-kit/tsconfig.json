{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"importHelpers": true,
		"types": ["node"],
		"lib": ["ES2022"],
		"declaration": true,
		"declarationMap": true,
		"noEmit": true,
		"outDir": "./dist",
		"rootDir": ".",
		"ignoreDeprecations": "6.0",
		"baseUrl": ".",
		"paths": {
			"@owlat/plugin-kit": ["./src/index.ts"]
		}
	},
	"include": ["src/**/*.ts", "scripts/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
