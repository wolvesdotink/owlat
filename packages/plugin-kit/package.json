{
	"name": "@owlat/plugin-kit",
	"version": "0.1.0",
	"description": "Public contracts for building Owlat plugins",
	"homepage": "https://owlat.app",
	"license": "Apache-2.0",
	"files": [
		"src/capabilities.ts",
		"src/context.ts",
		"src/index.ts",
		"src/json.ts",
		"src/manifest.ts"
	],
	"type": "module",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest watch",
		"test:coverage": "vitest run --coverage",
		"lint": "oxlint --config ../../oxlintrc.json src",
		"lint:fix": "oxlint --config ../../oxlintrc.json src --fix",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@vitest/coverage-v8": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
