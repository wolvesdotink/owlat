{
	"name": "@owlat/smtp-listener",
	"version": "0.3.2",
	"private": true,
	"license": "Apache-2.0",
	"homepage": "https://owlat.app",
	"description": "In-house SMTP listener — raw-net command loop, byte budget, and timeouts (replaces smtp-server on the inbound path)",
	"type": "module",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"scripts": {
		"lint": "oxlint --config ../../oxlintrc.json src",
		"lint:fix": "oxlint --config ../../oxlintrc.json src --fix",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@types/smtp-server": "^3.5.10",
		"@vitest/coverage-v8": "catalog:",
		"smtp-server": "^3.13.0",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
