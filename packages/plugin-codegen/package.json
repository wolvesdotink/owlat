{
	"name": "@owlat/plugin-codegen",
	"version": "0.3.3",
	"private": true,
	"description": "Validated build-time composition for bundled Owlat plugins",
	"license": "Apache-2.0",
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"prepare:contracts": "bun run --cwd ../plugin-kit build",
		"test": "bun run prepare:contracts && vitest run",
		"test:watch": "bun run prepare:contracts && vitest watch",
		"test:coverage": "bun run prepare:contracts && vitest run --coverage",
		"lint": "oxlint --config ../../oxlintrc.json src scripts",
		"lint:fix": "oxlint --config ../../oxlintrc.json src scripts --fix",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@owlat/plugin-host": "workspace:*",
		"@owlat/plugin-kit": "workspace:*",
		"@vue/compiler-sfc": "^3.5.33",
		"typescript": "catalog:"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"convex": "catalog:convex",
		"convex-test": "^0.0.54",
		"esbuild": "0.27.0",
		"vitest": "catalog:"
	}
}
