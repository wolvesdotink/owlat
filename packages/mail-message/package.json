{
	"name": "@owlat/mail-message",
	"version": "1.0.0",
	"private": true,
	"license": "Apache-2.0",
	"homepage": "https://owlat.app",
	"type": "module",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./parse/headers": {
			"types": "./src/parse/headers.ts",
			"import": "./src/parse/headers.ts"
		},
		"./compose/headers": {
			"types": "./src/compose/headers.ts",
			"import": "./src/compose/headers.ts"
		},
		"./compose/encoding": {
			"types": "./src/compose/encoding.ts",
			"import": "./src/compose/encoding.ts"
		},
		"./compose/messageId": {
			"types": "./src/compose/messageId.ts",
			"import": "./src/compose/messageId.ts"
		}
	},
	"scripts": {
		"lint": "oxlint --config ../../oxlintrc.json src __tests__",
		"lint:fix": "oxlint --config ../../oxlintrc.json src __tests__ --fix",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"test:coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@types/mailparser": "^3.4.5",
		"@types/node": "catalog:",
		"@types/nodemailer": "^8.0.0",
		"@vitest/coverage-v8": "catalog:",
		"mailparser": "^3.7.0",
		"nodemailer": "^9.0.3",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
