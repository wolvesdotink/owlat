{
	"name": "@owlat/mail-auth",
	"version": "0.3.2",
	"private": true,
	"license": "Apache-2.0",
	"homepage": "https://owlat.app",
	"description": "In-house email authentication — RFC 7208 SPF, RFC 7489 DMARC, RFC 6376 DKIM canonicalization + verification, and a cached injectable DNS resolver",
	"type": "module",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"scripts": {
		"lint": "oxlint --config ../../oxlintrc.json src",
		"lint:fix": "oxlint --config ../../oxlintrc.json src --fix",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"ioredis-mock": "^8.9.0",
		"mailauth": "^4.13.3",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"dependencies": {
		"@owlat/shared": "workspace:*"
	}
}
