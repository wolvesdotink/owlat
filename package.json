{
	"name": "owlat",
	"version": "0.3.3",
	"private": true,
	"description": "Owlat — self-hosted, modular email platform: marketing campaigns, team inbox, personal mailbox, and an AI agent, gated by a single feature-flag system.",
	"keywords": [
		"convex",
		"email",
		"inbox",
		"marketing",
		"nuxt",
		"self-hosted",
		"vue"
	],
	"homepage": "https://owlat.app",
	"bugs": {
		"url": "https://github.com/wolvesdotink/owlat/issues"
	},
	"license": "Apache-2.0",
	"author": "wolves <npm@wolves.ink>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wolvesdotink/owlat.git"
	},
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*",
			"!packages/sdk-java",
			"examples/conformance",
			"examples/plugins/*"
		],
		"catalog": {
			"typescript": "^6.0.3",
			"vitest": "^4.1.5",
			"@vitest/coverage-v8": "^4.1.5",
			"@types/node": "^25.6.0",
			"vue-tsc": "^3.2.7"
		},
		"catalogs": {
			"vue": {
				"vue": "^3.5.33",
				"nuxt": "^4.4.2",
				"@nuxtjs/color-mode": "^4.0.0",
				"@nuxt/fonts": "^0.14.0",
				"tailwindcss": "^4.2.4",
				"@tailwindcss/vite": "^4.2.4"
			},
			"convex": {
				"convex": "^1.36.1",
				"better-auth": ">=1.6.13 <1.6.16",
				"@convex-dev/better-auth": "^0.12.0"
			},
			"ai": {
				"ai": "^6.0.168",
				"@ai-sdk/anthropic": "3.0.71",
				"@ai-sdk/azure": "^3.0.0",
				"@ai-sdk/google": "3.0.91",
				"@ai-sdk/openai": "^3.0.53",
				"@ai-sdk/openai-compatible": "2.0.40"
			}
		}
	},
	"scripts": {
		"setup": "bun --cwd apps/setup-cli src/index.ts quickstart",
		"dev": "bun --env-file=.env --env-file=.env.local run turbo dev --filter=@owlat/web --filter=@owlat/api",
		"dev:web": "bun --env-file=.env --env-file=.env.local run turbo dev --filter=@owlat/web",
		"dev:api": "bun --env-file=.env --env-file=.env.local run turbo dev --filter=@owlat/api",
		"dev:docs": "bun --env-file=.env --env-file=.env.local run turbo dev --filter=@owlat/docs",
		"dev:marketing": "bun --env-file=.env --env-file=.env.local run turbo dev --filter=@owlat/marketing",
		"dev:seed": "bun scripts/dev-seed.ts",
		"build": "turbo build",
		"build:web": "turbo build --filter=@owlat/web",
		"build:docs": "turbo build --filter=@owlat/docs",
		"build:marketing": "turbo build --filter=@owlat/marketing",
		"typecheck": "turbo typecheck",
		"lint": "turbo lint",
		"lint:fix": "turbo lint:fix",
		"lint:deadcode": "bash scripts/check-dead-code.sh",
		"lint:filesize": "bash scripts/check-file-size.sh",
		"lint:adr": "bash scripts/check-adr-numbers.sh",
		"lint:branding": "bash scripts/check-branding.sh",
		"lint:format": "bash scripts/check-format.sh",
		"lint:imports": "bash scripts/check-cross-package-imports.sh",
		"lint:docker-workspaces": "bash scripts/check-docker-workspaces.sh",
		"lint:plugin-imports": "bun run plugins:prepare && bun packages/plugin-codegen/src/cli.ts --boundaries-only",
		"plugins:prepare": "bun run --cwd packages/plugin-kit build",
		"plugins:codegen": "bun run plugins:prepare && bun packages/plugin-codegen/src/cli.ts",
		"plugins:check": "bun run plugins:prepare && bun packages/plugin-codegen/src/cli.ts --check",
		"plugins:test-clean": "bun packages/plugin-codegen/scripts/cleanCheckoutSmoke.ts",
		"plugins:test-api-graph": "bun packages/plugin-codegen/scripts/apiTestGraphSmoke.ts",
		"plugins:test-convex-bundle": "bun run plugins:prepare && node packages/plugin-codegen/scripts/convexBundleSmoke.ts",
		"plugins:test-deploy-graph": "bun packages/plugin-codegen/scripts/deployGraphSmoke.ts",
		"deploy:api": "turbo deploy --filter=@owlat/api",
		"ox:lint": "oxlint --config oxlintrc.json",
		"ox:lint:fix": "oxlint --config oxlintrc.json --fix",
		"ox:fmt": "oxfmt --config oxfmtrc.json .",
		"ox:fmt:check": "oxfmt --config oxfmtrc.json --check .",
		"ci:lint": "bun run plugins:check && turbo lint --filter='!@owlat/desktop' && bun run lint:deadcode && bun run lint:filesize && bun run lint:adr && bun run lint:branding && bun run lint:format && bun run lint:imports && bun run lint:docker-workspaces && bun run lint:plugin-imports",
		"ci:typecheck": "turbo typecheck --filter='!@owlat/desktop'",
		"ci:test": "turbo test --filter='!@owlat/desktop'",
		"ci:test:coverage": "turbo test:coverage --filter='!@owlat/desktop'",
		"ci:verify": "bun run plugins:test-api-graph && bun run plugins:check && turbo lint typecheck test --filter='!@owlat/desktop' && bun run lint:deadcode && bun run lint:filesize && bun run lint:adr && bun run lint:branding && bun run lint:format && bun run lint:imports && bun run lint:docker-workspaces && bun run lint:plugin-imports",
		"test": "turbo test",
		"test:watch": "turbo test:watch",
		"goldens:update": "bun --cwd packages/mail-message run goldens:update",
		"release:cut": "bun scripts/release.ts",
		"changeset": "changeset",
		"changeset:version": "changeset version",
		"changeset:publish": "changeset publish",
		"release": "bun run build && bun run changeset:publish"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"knip": "6.23.0",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.69.0",
		"turbo": "^2.9.18"
	},
	"overrides": {
		"brace-expansion": "^5.0.7",
		"devalue": "^5.8.1",
		"fast-xml-builder": "^1.2.0",
		"js-cookie": "^3.0.8",
		"js-yaml": "^3.15.0",
		"linkify-it": "^5.0.1",
		"nuxt": "4.4.2",
		"protobufjs": "^7.6.5",
		"shell-quote": "^1.10.0",
		"tar": "^7.5.20",
		"tmp": "^0.2.7",
		"undici": "^7.28.0",
		"vite": "^7.3.5",
		"ws": "^8.21.0"
	},
	"packageManager": "bun@1.3.11",
	"patchedDependencies": {
		"nodemailer@9.0.3": "patches/nodemailer@9.0.3.patch"
	},
	"trustedDependencies": [
		"@owlat/ui",
		"better-sqlite3"
	],
	"dependencies": {
		"nuxt": "4.4.2",
		"vite": "7.3.1"
	}
}
